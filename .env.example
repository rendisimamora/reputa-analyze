# ----- ReputaScan ID Environment -----

# PostgreSQL connection string (REQUIRED)
DATABASE_URL="postgresql://rendisimamora@localhost:5432/db_reputa?schema=public"

# ===== AI PROVIDER =====
# Pilih salah satu: openai | groq | ollama | openrouter
# groq = GRATIS, no credit card, super cepat (RECOMMENDED untuk dev/personal)
# openai = berbayar, premium
# ollama = lokal di laptop kamu, 100% gratis, butuh install Ollama
# openrouter = mixed gratis/berbayar
AI_PROVIDER="groq"

# Opsional: paksa model tertentu. Kosongkan untuk pakai default per-provider.
#   groq default: llama-3.3-70b-versatile
#   openai default: gpt-4o-mini
#   ollama default: llama3.2:3b
#   openrouter default: meta-llama/llama-3.3-70b-instruct:free
AI_MODEL=""

# Isi key sesuai provider yang dipilih di atas:
GROQ_API_KEY=""             # daftar gratis di https://console.groq.com (no credit card)
OPENAI_API_KEY=""           # https://platform.openai.com
OPENROUTER_API_KEY=""       # https://openrouter.ai/keys
OLLAMA_BASE_URL="http://localhost:11434/v1"   # default Ollama local

# ===== AUTH =====
# Iron-session cookie secret - generate a random 32+ char string (REQUIRED)
SESSION_PASSWORD="change-me-to-a-random-32+character-string-please"

# ===== CRAWLER =====
CRAWLER_USER_AGENT="ReputaScanBot/1.0 (+https://reputascan.id/bot; contact@reputascan.id)"
CRAWLER_DELAY_MS="2500"
CRAWLER_CONCURRENCY="4"
CRAWLER_MAX_RETRIES="2"
SCAN_CRON="*/30 * * * *"
MAX_ARTICLES_PER_SOURCE="40"

# JWT — wajib min 32 karakter random buat production.
JWT_SECRET=please-generate-with: openssl rand -base64 48
# Optional: token lifetime (detik). Default 7 hari.
# JWT_TTL_SECONDS=604800
