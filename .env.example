# ----- ReputaScan ID Environment -----
# PostgreSQL connection string (REQUIRED)
DATABASE_URL="postgresql://rendisimamora@localhost:5432/db_reputa?schema=public"

# OpenAI API key - used ONLY for sentiment analysis (REQUIRED)
OPENAI_API_KEY=""

# OpenAI model for sentiment analysis (default: gpt-4o-mini)
OPENAI_MODEL="gpt-4o-mini"

# Iron-session cookie secret - generate a random 32+ char string (REQUIRED)
SESSION_PASSWORD="change-me-to-a-random-32+character-string-please"

# Crawler user-agent identifier (REQUIRED, must be polite & identifiable)
CRAWLER_USER_AGENT="ReputaScanBot/1.0 (+https://reputascan.id/bot; contact@reputascan.id)"

# Per-domain delay in ms between requests (default 2500)
CRAWLER_DELAY_MS="2500"

# Max concurrent fetches across all domains (default 4)
CRAWLER_CONCURRENCY="4"

# Max retries per failed request (default 2)
CRAWLER_MAX_RETRIES="2"

# Scan cadence cron expression (default: every 30 minutes)
SCAN_CRON="*/30 * * * *"

# Maximum articles per source per scan (safety cap)
MAX_ARTICLES_PER_SOURCE="40"
