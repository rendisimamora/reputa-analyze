// ReputaScan ID - Prisma schema (UUIDv7 + slug routing)
// PostgreSQL only

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- AUTH ----------

model User {
  id           String   @id @default(uuid(7)) @db.Uuid
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects Project[]
}

// ---------- MONITORING ----------

model Project {
  id          String   @id @default(uuid(7)) @db.Uuid
  userId      String   @db.Uuid

  // URL identifier: lowercase-hyphenated, per-user unique, immutable after create.
  // Routes use slug; foreign keys keep using UUID `id`.
  slug        String

  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastScanAt  DateTime?

  // Soft delete: when set, project is hidden from lists & blocked from access.
  // Data (mentions, alerts, scans, reports) is preserved.
  deletedAt   DateTime?

  // Cached AI executive summary — regenerated after each scan/reanalyze that
  // produces new analyzed mentions. Dashboard reads from here instead of
  // calling the LLM on every load.
  aiExecutive       String?   @db.Text
  aiRecommendation  String?   @db.Text
  aiSummaryAt       DateTime?
  aiSummaryError    String?   @db.Text

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords  Keyword[]
  mentions  Mention[]
  alerts    Alert[]
  reports   Report[]
  scans     ScanRun[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([deletedAt])
}

model Keyword {
  id        String   @id @default(uuid(7)) @db.Uuid
  projectId String   @db.Uuid
  term      String
  matchMode MatchMode @default(ANY)
  createdAt DateTime @default(now())

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@unique([projectId, term])
}

enum MatchMode {
  ANY
  ALL
}

// ---------- MENTIONS ----------

model Mention {
  id                String   @id @default(uuid(7)) @db.Uuid
  projectId         String   @db.Uuid
  sourceKey         String
  sourceName        String
  title             String
  snippet           String?  @db.Text
  url               String
  urlHash           String
  contentHash       String?
  author            String?
  publishedAt       DateTime?
  rawContent        String?  @db.Text
  matchedKeywords   String[] @default([])
  collectionMethod  CollectionMethod
  crawlStatus       CrawlStatus @default(OK)
  crawlError        String?
  createdAt         DateTime @default(now())

  sentiment         Sentiment?
  sentimentScore    Float?
  emotion           String?
  toxicity          Float?
  hateSpeech        Float?
  fakeNews          Float?
  topic             String?
  aiSummary         String?   @db.Text
  analyzedAt        DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, publishedAt])
  @@index([projectId, sentiment])
  @@index([projectId, sourceKey])
  @@unique([projectId, urlHash])
}

enum CollectionMethod {
  RSS
  SEARCH_PAGE
  ARTICLE_SCRAPE
}

enum CrawlStatus {
  OK
  RESTRICTED
  RATE_LIMITED
  ERROR
  PARTIAL
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

// ---------- SOURCES ----------

model SourceStat {
  id            String   @id @default(uuid(7)) @db.Uuid
  projectId     String?  @db.Uuid
  sourceKey     String
  lastFetchedAt DateTime?
  lastStatus    CrawlStatus @default(OK)
  totalFetched  Int      @default(0)
  totalErrors   Int      @default(0)
  lastError     String?

  @@unique([projectId, sourceKey])
  @@index([sourceKey])
}

// ---------- CRAWL LOGS ----------

model CrawlLog {
  id          String   @id @default(uuid(7)) @db.Uuid
  projectId   String?  @db.Uuid
  sourceKey   String
  method      CollectionMethod
  url         String
  status      CrawlStatus
  httpStatus  Int?
  message     String?  @db.Text
  durationMs  Int?
  createdAt   DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([sourceKey, createdAt])
}

// ---------- SCAN RUNS ----------

model ScanRun {
  id           String   @id @default(uuid(7)) @db.Uuid
  projectId    String   @db.Uuid
  trigger      ScanTrigger
  startedAt    DateTime @default(now())
  claimedAt    DateTime?
  finishedAt   DateTime?
  fetched      Int      @default(0)
  newMentions  Int      @default(0)
  analyzed     Int      @default(0)
  errors       Int      @default(0)
  status       ScanStatus @default(QUEUED)
  message      String?  @db.Text
  progressJson Json?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, startedAt])
  @@index([status, claimedAt])
}

enum ScanTrigger {
  MANUAL
  CRON
  ON_CREATE
}

enum ScanStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

// ---------- ALERTS ----------

model Alert {
  id         String   @id @default(uuid(7)) @db.Uuid
  projectId  String   @db.Uuid
  type       AlertType
  severity   AlertSeverity
  title      String
  message    String   @db.Text
  payload    Json?
  acknowledged Boolean  @default(false)
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

enum AlertType {
  NEGATIVE_SPIKE
  HIGH_TOXICITY
  REPUTATION_DROP
  CREDIBLE_NEGATIVE
  MULTI_SOURCE_NEGATIVE
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ---------- REPORTS ----------

model Report {
  id         String   @id @default(uuid(7)) @db.Uuid
  projectId  String   @db.Uuid
  title      String
  rangeFrom  DateTime
  rangeTo    DateTime
  payload    Json
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}
